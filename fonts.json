    },
    {
      "id": "syne",
      "name": "Syne",
      "import": "@import url('https://fonts.googleapis.com/css2?family=Syne:wght@700;800&display=swap');",
      "family": "'Syne', sans-serif",
      "weights": [700, 800],
      "recommended_weight": {"heading": 800, "body": null},
      "mood_tags": ["artistic", "avant-garde", "unique", "editorial"],
      "korean_support": false,
      "bold_readability": "good",
      "use_for": "heading",
      "pair_with": "noto-sans-kr",
      "note": "폭 넓은 독특한 영문 헤드라인. 아트/에디토리얼/포트폴리오 특화."
    },
    {
      "id": "playfair-display",
      "name": "Playfair Display",
      "import": "@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap');",
